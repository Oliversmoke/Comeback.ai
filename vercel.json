{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/.next",
  "installCommand": "cd client && npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://rickchat-api.onrender.com/api/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://rickchat-api.onrender.com",
    "NEXT_PUBLIC_SOCKET_URL": "wss://rickchat-api.onrender.com"
  }
}
