# RickChat Environment Configuration
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/rickchat
DATABASE_USER=rickchat
DATABASE_PASSWORD=rickchat
DATABASE_POOL_SIZE=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Firebase
FIREBASE_PROJECT_ID=rickchat-dev
FIREBASE_CREDENTIALS_PATH=/etc/secrets/firebase.json
FIREBASE_STORAGE_BUCKET=rickchat-dev.appspot.com

# Google Cloud
GOOGLE_CLOUD_PROJECT=rickchat-dev
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/gcp.json

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=gpt-4

# Storage
STORAGE_BUCKET=rickchat-files-dev

# Queue
QUEUE_TYPE=in_memory
